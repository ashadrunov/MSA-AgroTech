
@startuml
!includeurl https://raw.githubusercontent.com/RicardoNiepel/C4-PlantUML/master/C4_Component.puml
    title Контейнерная диаграмма PigFarm

    Person(livestockSpecialist, "Зоотехник", "Следит за запасами еды и прогнозирует расход")
    Person(livestockBreeder, "Животновод", "осществляет кормление и поение животных")
    Person(Veterinar, "Ветеринар", "Следит за состоянием животных")
    Person(TechnicalSpecialist, "Техник", "Технический специалист, обслуживающий оборудование")
    Person(Manager, "Руководитель", "Руководитель, анали")
    Person(TechnicalSpecialist, "Техник", "Технический специалист, обслуживающий оборудование")
    Person(Stockman, "Кладовщик", "Сотрудник склада, осуществляющий отгрузку")

    System_Boundary(local_agent, "Локальный агент") {
        Component(mobile_app, "Мобильное приложение", "React Native", "Личный кабинет ветеринара, оповещения об инцидентах")
        Component(web_app, "Личный кабинет", "Angular", "Личный кабинет сотрудника")
        Component(api, "API Gateway", "Spring Boot", "Обработка запросов")
        Component(auth, "Auth Service", "Java", "Аутентификация")
        Component(FoodStock, "Планирование рациона", "Java", "Контроль запасов и прогнозирование расхода кормов")
        Component(scheduler, "Управление кормушками", "Java", "Управление кормушками и поилками")
        Component(WaterMonitor, "Анализатор фильтрации воды", "Java", "Анализатор фильтрации воды")
        Component(AiAgents, "ИИ агенты", "ML", "ИИ агенты для мониторинга инцидентов и состояния животных")
        Component(AnimalMonitoringService, "Сервис мониторинга животных", "Java", "Принимает события мониторинга с ИИ агентов и предоставляет данные пользователю")
        Component(VideoDrivers, "Видеодрайверы", "C++", "Драйверы для камер видеонаблюдения")
        Component(WaterSensorDriver, "Драйвер дачика чистоты воды", "C++", "Драйверы для датчика чистоты воды")
        Component(OrderService, "Сервис заказов", "Java", "Сервис размещения заказов")
        Component(ReplicationService, "Сервис репликации", "Java", "Сервис репликации данных")
        Component(db, "Локальная база данных", "PostgreSQL", "Хранение данных")
    }

    System_Boundary(central_office_system, "Центральный офис") {
        Component(central_web_app, "React Native", "Личный кабинет руководства компании")
        Component(stock_web_app, "React Native", "Личный кабинет работников склада и сотрудников, делающих заказы")
        Component(central_api, "API Gateway", "Spring Boot", "Обработка запросов")
        Component(central_auth, "Auth Service", "Java", "Аутентификация")
        Component(analiticService, "Сервис аналитики", "Отчеты мониторинга скота для руководства")
        Component(stockService, "Управление складом", "Сервис приема и управления состояния заказов")
        Component(EnterpriseServiceBus, "Корпоративная сервисная шина", "Kafka", "Корпоративная сервисная шина")
        Component(central_db, "Центральная база данных", "PostgreSQL", "Хранение данных")
    }

    Rel(Veterinar, mobile_app, "Использует приложение")
    Rel(Veterinar, web_app, "Входит в ЛК")
    Rel(livestockSpecialist, web_app, "Входит в ЛК")
    Rel(livestockBreeder, web_app, "Входит в ЛК")
    Rel(TechnicalSpecialist, web_app, "Входит в ЛК")
    Rel(web_app, api, "API запросы")
    Rel(mobile_app, api, "API запросы")
    Rel(api, auth, "Проверка доступа")
    Rel(api, scheduler, "Запрос плана кормления и поения животных")
    Rel(api, FoodStock, "Ввод данных о поставках и запасах еды")
    Rel(FoodStock, scheduler, "Планирование расхода еды")
    Rel(api, WaterMonitor, "Получение данных о фильтрации воды")
    Rel(WaterSensorDriver, WaterMonitor, "Оцифрованный поток данных с датчиков состояния воды")
    Rel(api, AiAgents, "Запрос данных мониторинга животных")
    Rel(api, OrderService, "Запрос событий мониторинга")
    Rel(api, AnimalMonitoringService, "События мониторинга")
    Rel(AiAgents, AnimalMonitoringService, "События мониторинга")
    Rel(VideoDrivers, AiAgents, "Оцифрованные поток данных с камер")
    Rel(auth, db, "Чтение/запись данных")
    Rel(scheduler, db, "Чтение/запись данных")
    Rel(FoodStock, db, "Чтение/запись данных")
    Rel(OrderService, db, "Чтение/запись данных")
    Rel(auth, db, "Чтение/запись данных")
    Rel(ReplicationService, db, "Чтение данных")
    Rel(ReplicationService, EnterpriseServiceBus, "Отправка заказов и данных для аналитики в центральную систему")
    Rel(EnterpriseServiceBus, OrderService, "Изменения статуса заказов")

    Rel(central_web_app, central_api, "API запросы")
    Rel(central_api, central_auth, "Авторизация пользователей")
    Rel(central_api, analiticService, "Создание отчетов о состоянии скота")
    Rel(EnterpriseServiceBus, analiticService, "Поток данных мониторинга с каждой фермы")
    Rel(analiticService, central_db, "Чтение/запись данных")
    Rel(stock_web_app, central_api, "API запросы")
    Rel(central_api, stockService, "Управление заказами")
    Rel(stockService, central_db, "Чтение/запись данных")
    Rel(TechnicalSpecialist, stock_web_app, "Управление заказами")
    Rel(Stockman, stock_web_app, "Управление заказами")
    Rel(Manager, central_web_app, "Просмотр статистики")

@enduml
